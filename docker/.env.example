# Chain selection: "bitcoin" (default) or "litecoin"
# CHAIN=bitcoin

# Path to the blockchain node's data directory
# Bitcoin:  CHAIN_DATA_DIR=/path/to/bitcoin
# Litecoin: CHAIN_DATA_DIR=/path/to/litecoin
CHAIN_DATA_DIR=/path/to/bitcoin

# RPC connection settings
RPC_HOST=localhost
# RPC_USER=your_rpc_username
# RPC_PASSWORD=your_rpc_password

# Optional: use a BRK data bind-mount instead of the named volume
# BRK_DATA_DIR=./brk-data
